($begin
  ($define! fib-iter
    ($lambda (n a b)
             ($if (eq? n 0)
                  a
                  (fib-iter (- n 1) b (+ a b)))))

  ($define! fib ($lambda (n) (fib-iter n 1 1)))

  ($define! stress ($lambda (i n) ($if (eq? i n)
                                     ()
                                     ($begin
                                       (displayln! (fib i))
                                       (stress (+ i 1) n)))))

  (stress 0 1024)
)
