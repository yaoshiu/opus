($begin
  ($define! fib-iter
    ($lambda (n a b)
             ($if (= n 0)
                  a
                  (fib-iter (- n 1) b (+ a b)))))

  ($define! fib ($lambda (n) (fib-iter n 1 1)))

  ($define! test ($lambda (i n) ($if (= i n)
                                     ()
                                     ($begin
                                       (displayln! (fib i))
                                       (test (+ i 1) n)))))

  (test 0 1024)
)
